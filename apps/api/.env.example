# Veritabanı (lokal: localhost:5433, Docker: postgres:5432)
DATABASE_URL=postgresql://postgres:ŞİFRE@localhost:5433/proteinshopbackend

# JWT (üretmek için: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Redis: Lokal (npm run dev)=localhost | Sunucu/Docker=redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP - Gmail için:
# 1. Google Hesap > Güvenlik > 2 Adımlı Doğrulama AÇ
# 2. Uygulama şifreleri > Mail için şifre oluştur
# 3. EMAIL_PASSWORD olarak o 16 haneli kodu girin
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=
